# Forzar finales de línea LF (Unix) — crítico para los scripts que corren en el VPS.
# Evita el error "bad interpreter: /bin/bash^M" al clonar desde Windows.
*.sh    text eol=lf
*.js    text eol=lf
*.conf  text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.md    text eol=lf
.env.example text eol=lf

# ============================================================
#  TecXPaneL — Variables de entorno
#  Copia a /opt/txpl/.env y rellena los valores.
#  chmod 600 /opt/txpl/.env  (NUNCA lo subas a git)
# ============================================================

# Puerto local del backend (nginx hace de proxy hacia aquí)
TXPL_PORT=8585

# Directorio base de instalación
TXPL_DIR=/opt/txpl

# Directorio donde se crean los sitios web (jaula del gestor de archivos)
SITES_DIR=/var/www

# Secreto para firmar los JWT — MÍNIMO 32 caracteres aleatorios.
# Genera uno con:  openssl rand -hex 32
JWT_SECRET=

# Tiempo de vida del token de sesión (ej: 8h, 1d, 30m)
TXPL_TOKEN_TTL=8h

# Usuario administrador del panel
ADMIN_USER=admin
# Contraseña inicial del admin (se guarda hasheada con bcrypt en el primer arranque).
# Tras el primer arranque puedes borrar esta línea; para rotarla, ponla de nuevo
# y arranca una vez con TXPL_RESET_ADMIN_PASS=1
ADMIN_PASS=

# Contraseña root de MySQL/MariaDB (necesaria para crear bases de datos)
MYSQL_ROOT_PASSWORD=

# Contraseña de PostgreSQL (opcional)
PG_PASSWORD=

# Email para los certificados Let's Encrypt (certbot)
SSL_EMAIL=
